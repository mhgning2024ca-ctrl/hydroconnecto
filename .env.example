# HydroConnecto — exemple de configuration
# Copier ce fichier en .env en local et remplir les vraies valeurs.

SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=ta_publishable_key_anon_ici
# Recommandé côté serveur pour uploads persistants Supabase Storage :
SUPABASE_SERVICE_ROLE_KEY=

# Local seulement. En production, ne pas forcer PORT si la plateforme fournit sa variable.
PORT=3000

ADMIN_EMAIL=admin@hydroconnecto.local
ADMIN_PASSWORD=change-moi-123
ADMIN_NAME=Moustapha Gning
ADMIN_ROLE=directeur
COOKIE_SECRET=hydroconnecto-local-secret-cookie-a-changer-en-production
NODE_ENV=development

# Identifiants locaux par défaut pour tester :
# Email : admin@hydroconnecto.local
# Mot de passe : change-moi-123
# À CHANGER impérativement avant publication.


# Connexion :
# 1) Le compte directeur ci-dessus fonctionne toujours.
# 2) Les utilisateurs créés dans l'admin se connectent avec leur email + password_temp.
#    Le compte est bloqué seulement si statut = refuse / suspendu / desactive.

# Rôles et permissions :
# Les utilisateurs créés dans l'admin doivent avoir statut=approuve pour se connecter.
# Les permissions sont appliquées côté serveur selon le rôle.

# Déploiement Vercel : ajoute ces variables dans Vercel Project Settings > Environment Variables.
