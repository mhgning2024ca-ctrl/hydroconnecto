{
  "version": 2,
  "installCommand": "npm install --no-package-lock --legacy-peer-deps --no-audit --no-fund",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/**",
          "sql/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}